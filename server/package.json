{
    "name": "widymotret-backend",
    "version": "1.0.0",
    "description": "Backend API for Widymotret Photography",
    "main": "src/index.ts",
    "scripts": {
        "start": "npx prisma generate && npx ts-node --transpile-only src/index.ts",
        "dev": "npx ts-node --transpile-only src/index.ts",
        "seed": "npx ts-node --transpile-only src/seed.ts",
        "prisma:generate": "npx prisma generate",
        "prisma:migrate": "npx prisma migrate dev --name init",
        "prisma:studio": "npx prisma studio"
    },
    "dependencies": {
        "@prisma/client": "^6.5.0",
        "@types/multer": "^2.0.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/node": "^22.13.9",
        "prisma": "^6.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.2"
    }
}
